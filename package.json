{
  "name": "briya-room-reservations-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --restart-tries 5 --restart-after 1000 --prefix \"[{name}]\" --names \"backend,frontend\" --prefix-colors \"bgCyan.black,bgMagenta.white\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "restart": "npm run dev",
    "install:all": "npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
