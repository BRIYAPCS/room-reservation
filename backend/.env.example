# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
APP_TIMEZONE=America/New_York
# Your GitHub Pages domain (or custom domain pointing to GitHub)
FRONTEND_URL=https://your-github-pages-domain.com

# ── MySQL ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=briya
DB_PASSWORD=your_secure_password
DB_NAME=briya_room_reservations

# ── Auth PINs ─────────────────────────────────────────────────
PIN_ADMIN=your_admin_pin
PIN_STANDARD=your_standard_pin

# ── JWT ───────────────────────────────────────────────────────
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_96_char_hex_secret

# ── Email (Resend) ────────────────────────────────────────────
# Sign up free at https://resend.com to get an API key.
# Leave blank to fall back to console.log (dev/staging only).
RESEND_API_KEY=your_resend_api_key
# Sender shown in email clients — must match a verified Resend domain
EMAIL_FROM=Briya Room Reservations <noreply@briya.org>

# ── OTP settings ─────────────────────────────────────────────
OTP_EXPIRATION_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=300
OTP_MAX_ATTEMPTS=5

# ── Power Automate ────────────────────────────────────────────
# Webhook URL that receives { email } and returns { valid: true/false, name: "..." }
# Leave blank to skip email verification (users will be prompted for name manually)
POWER_AUTOMATE_WEBHOOK_URL=https://prod-xx.eastus.logic.azure.com/workflows/...

# ── Booking window ───────────────────────────────────────────
BOOKING_START_HOUR=8
BOOKING_END_HOUR=21
SLOT_DURATION_MINUTES=15

# ── Weekend settings ──────────────────────────────────────────
ALLOW_WEEKENDS=true
ALLOW_WEEKEND_BOOKINGS=false

# ── Booking rules ─────────────────────────────────────────────
ALLOW_PAST_BOOKINGS=false
ALLOW_DOUBLE_BOOKING=true
REQUIRE_LOGIN_FOR_CALENDAR=true

# ── Recurring events ──────────────────────────────────────────
ENABLE_RECURRING_EVENTS=true
RECURRING_MAX_MONTHS=12

# ── Business hours ────────────────────────────────────────────
BUSINESS_START=08:00
BUSINESS_END=17:00
BUSINESS_DAYS=1,2,3,4,5

# ── Permissions ───────────────────────────────────────────────
CAN_CREATE_ROLES=admin,standard
EDIT_OTHERS_ROLE=admin
DELETE_ROLE=admin

# ── Weather Widget ────────────────────────────────────────────
# Set WEATHER_ENABLED=true to show the widget, false to hide it
WEATHER_ENABLED=true
WEATHER_CITY=Washington, DC
WEATHER_LAT=38.9072
WEATHER_LON=-77.0369

# ── Visitor Counter ──────────────────────────────────────────
# Set to true to show the visitor counter widget on the Home page
VISITOR_COUNTER_ENABLED=true

# ── Weather Test Override (DEV ONLY — leave empty in production) ──
# Valid values: rain | drizzle | storm | snow | sunny | cloudy | fog
WEATHER_TEST_CONDITION=
